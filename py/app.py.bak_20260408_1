def evaluate_market_state(latest_metrics, signals):
    score = 0
    reasons = []
    checks = [
        (latest_metrics["close"] > latest_metrics["ma20"], "浠锋牸杩愯浜?MA20 涓婃柟", "浠锋牸杩愯浜?MA20 涓嬫柟"),
        (latest_metrics["close"] > latest_metrics["ma60"], "浠锋牸杩愯浜?MA60 涓婃柟", "浠锋牸杩愯浜?MA60 涓嬫柟"),
        (latest_metrics["ma20"] > latest_metrics["ma60"], "涓湡鍧囩嚎缁撴瀯鍋忓己", "涓湡鍧囩嚎缁撴瀯鍋忓急"),
        (latest_metrics["macd"] > 0, "MACD 浣嶄簬闆惰酱涓婃柟", "MACD 浣嶄簬闆惰酱涓嬫柟"),
    ]
    for condition, pos_text, neg_text in checks:
        score += 1 if condition else -1
        reasons.append(pos_text if condition else neg_text)
    for key, pos_text, neg_text in [
        ("inventory_bias", "搴撳瓨绔浠锋牸褰㈡垚鏀拺", "搴撳瓨绔浠锋牸褰㈡垚鍘嬪埗"),
        ("basis_bias", "鏈熺幇缁撴瀯鍋忓己", "鏈熺幇缁撴瀯鍋忓急"),
        ("news_bias", "娑堟伅鎯呯华鍋忔闈?, "娑堟伅鎯呯华鍋忚礋闈?),
    ]:
        if signals.get(key) == "bullish":
            score += 1
            reasons.append(pos_text)
        elif signals.get(key) == "bearish":
            score -= 1
            reasons.append(neg_text)
    if score >= 4:
        bias, confidence = "鍋忓", "杈冨己"
    elif score >= 1:
        bias, confidence = "鍋忓", "涓瓑"
    elif score <= -4:
        bias, confidence = "鍋忕┖", "杈冨己"
    elif score <= -1:
        bias, confidence = "鍋忕┖", "涓瓑"
    else:
        bias, confidence = "闇囪崱", "涓瓑"
    return {"score": score, "bias": bias, "confidence": confidence, "reasons": reasons}


