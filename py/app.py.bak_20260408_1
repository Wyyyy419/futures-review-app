def classify_news_sentiment(text_blob):
    bullish_words = ["鎻愭尟", "鍑忎骇", "鍘诲簱", "鏀拺", "绱у紶", "涓婃定", "鏀瑰杽"]
    bearish_words = ["鍥炶惤", "璧板急", "澧炰骇", "绱簱", "涓嬭穼", "鍘嬪埗", "鐤插急"]
    bullish_score = sum(word in text_blob for word in bullish_words)
    bearish_score = sum(word in text_blob for word in bearish_words)
    if bullish_score > bearish_score:
        return "bullish", "鐩稿叧鏂伴椈瀵圭洏闈㈡儏缁亸姝ｉ潰锛屼絾浠嶉渶瑙傚療鍏舵槸鍚︽寔缁紶瀵煎埌渚涢渶绔€?
    if bearish_score > bullish_score:
        return "bearish", "鐩稿叧鏂伴椈瀵圭洏闈㈡儏缁亸璐熼潰锛岀煭绾块渶闃茶寖鎯呯华缁х画鍙戦叺銆?
    return "neutral", "娑堟伅闈㈠鐩橀潰褰卞搷鍋忎腑鎬э紝鐭嚎浠嶉渶鏇村璺熻釜楠岃瘉銆?


